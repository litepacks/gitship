{
  "name": "deploykit-monorepo",
  "version": "0.0.1",
  "private": true,
  "description": "Lightweight GitHub-driven deployment toolkit",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build -w @deploykit/shared && npm run build -w @deploykit/core && npm run build -w @deploykit/agent && npm run build -w @deploykit/cli",
    "test": "vitest run",
    "coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.9",
    "tsx": "^4.11.0",
    "typescript": "^5.4.5",
    "vitest": "^4.1.9"
  }
}
